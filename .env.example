# Server
PORT=4000
CORS_ORIGIN=http://localhost:3000

# Database
# LOCAL DEV (docker-compose): dùng chuỗi dưới đây, khớp docker-compose.yml
DATABASE_URL=postgresql://freetune:freetune@localhost:5432/freetune_dev?schema=public
# PRODUCTION (Neon): thay bằng connection string lấy từ Neon dashboard, có sslmode=require
# DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require

# Auth
JWT_SECRET=change-me-in-production
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# Music sources
PIXABAY_API_KEY=
JAMENDO_CLIENT_ID=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Internal
INTERNAL_SYNC_SECRET=change-me
